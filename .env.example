# Copia este archivo a .env y rellena (todo el plan free tier)

# Supabase (gratis): https://supabase.com → New project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Opcional — bot de Telegram (gratis): username sin @
# VITE_TELEGRAM_BOT=RutaDosBot

# Opcional — más POIs: https://opentripmap.io/product (API key free)
# VITE_OPENTRIPMAP_KEY=
