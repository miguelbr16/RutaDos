# Copiá este archivo a .env y rellená los valores.
# El archivo .env NO se sube a GitHub.

# --- Supabase (sync pareja / share / bot backend) ---
# Dashboard: https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Telegram (botón azul que abre la app) ---
# Solo el USERNAME del bot (sin @). Lo ves en BotFather / en el perfil del bot.
# Ejemplo: si el bot es @RutaDosGuia_bot →
VITE_TELEGRAM_BOT=RutaDosGuia_bot

# --- Opcional: más sitios en el plan ---
# https://opentripmap.io/product (API key free)
# VITE_OPENTRIPMAP_KEY=

# =============================================================================
# NO pongáis aquí el TOKEN de BotFather (el largo tipo 123456:AAH...).
# Ese va en Supabase → Edge Functions → Secrets:
#   TELEGRAM_BOT_TOKEN=123456:AAH...
# =============================================================================
